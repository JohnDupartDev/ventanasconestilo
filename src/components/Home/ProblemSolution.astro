---
/* src/components/ProblemSolution.astro */
---

<section class="py-24 bg-[#0e0e0e] overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            
            <div class="reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out md:col-span-8 bg-[#1f1f1f] rounded-[2.5rem] p-8 md:p-16 flex flex-col justify-center border border-white/5 relative overflow-hidden group">
                <div class="absolute -top-24 -left-24 w-64 h-64 bg-[#dcef42]/5 blur-[100px] rounded-full group-hover:bg-[#dcef42]/10 transition-colors duration-700"></div>

                <h2 class="text-4xl md:text-5xl font-['Space_Grotesk'] font-black text-white mb-8 tracking-tighter leading-none">
                    ¿LUZ EXCESIVA O <br/>
                    <span class="text-[#dcef42] italic">CALOR SOFOCANTE?</span>
                </h2>
                
                <p class="text-white/50 text-base md:text-lg mb-10 max-w-xl font-sans italic leading-relaxed">
Sabemos que en la Sabana la luz del sol puede ser intensa. Con nuestras cortinas y persianas, le ayudamos a controlar la luz y proteger sus espacios del desgaste diario.
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="p-6 bg-[#131313] rounded-2xl border border-white/5 flex items-center gap-4 group/item hover:border-[#dcef42]/30 transition-colors">
                        <div class="w-12 h-12 rounded-lg bg-[#dcef42]/10 flex items-center justify-center">
                            <span class="material-icons-outlined text-[#dcef42]">thermostat</span>
                        </div>
                        <div>
                            <p class="text-white font-['Plus_Jakarta_Sans'] font-bold text-sm uppercase tracking-widest">Control Térmico</p>
                            <p class="text-[10px] text-white/30 uppercase tracking-tighter">Proteccón para el hogar</p>
                        </div>
                    </div>

                    <div class="p-6 bg-[#131313] rounded-2xl border border-white/5 flex items-center gap-4 group/item hover:border-[#dcef42]/30 transition-colors">
                        <div class="w-12 h-12 rounded-lg bg-[#dcef42]/10 flex items-center justify-center">
                            <span class="material-icons-outlined text-[#dcef42]">visibility_off</span>
                        </div>
                        <div>
                            <p class="text-white font-['Plus_Jakarta_Sans'] font-bold text-sm uppercase tracking-widest">Privacidad Total</p>
                            <p class="text-[10px] text-white/30 uppercase tracking-tighter">Control de luz</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="reveal opacity-0 translate-y-8 transition-all duration-1000 delay-300 ease-out md:col-span-4 bg-[#dcef42] rounded-[2.5rem] p-10 md:p-12 text-[#2e3300] flex flex-col justify-end relative overflow-hidden shadow-xl shadow-[#dcef42]/10 group">
                <span class="material-icons-outlined text-9xl opacity-10 absolute -top-4 -right-4 rotate-12 group-hover:rotate-45 transition-transform duration-1000">light_mode</span>
                
                <h3 class="text-3xl font-['Space_Grotesk'] font-black mb-6 leading-none tracking-tighter uppercase">La Solución <br/>Perfecta</h3>
                
                <p class="font-['Plus_Jakarta_Sans'] font-bold text-sm leading-relaxed opacity-80 uppercase tracking-wide">
                    Nuestras telas técnicas bloquean hasta el 99% de los rayos UV sin perder su vista al exterior.
                </p>

                <div class="mt-8 pt-8 border-t border-[#2e3300]/10">
                    <span class="text-[10px] font-black tracking-[0.3em] uppercase">Tus Ventanas con estilo 2026</span>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    // Sistema ultra-ligero de revelación al hacer scroll
    const observerOptions = {
        threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                entry.target.classList.add('opacity-100', 'translate-y-0');
            }
        });
    }, observerOptions);

    // Aplicar a todos los elementos con la clase .reveal
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>