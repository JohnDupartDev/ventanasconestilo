---
/* src/components/sheer-elegance/Hero.astro */
---

<style>
  @keyframes heroFadeUp {
    0% { opacity: 0; transform: translateY(40px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroImageZoom {
    0% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
  
  .anim-hero-zoom {
    animation: heroImageZoom 2.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .anim-hero-item {
    opacity: 0; 
    animation: heroFadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .anim-delay-1 { animation-delay: 100ms; }
  .anim-delay-2 { animation-delay: 250ms; }
  .anim-delay-3 { animation-delay: 400ms; }
  .anim-delay-4 { animation-delay: 550ms; }
</style>

<section class="relative min-h-[870px] flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img alt="Sheer Elegance Blinds" class="w-full h-full object-cover grayscale-[0.2] anim-hero-zoom" data-alt="Modern minimalist interior with Sheer Elegance blinds filtering soft morning light, showing alternating bands of translucent and opaque high-quality fabric" src="/images/cajica-cortinas-sheer-elegance.jpg"/>
    
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0e0e0e] via-[#0e0e0e]/60 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-8 pt-20 w-full">
    <div class="max-w-3xl">
      <span class="inline-block px-4 py-1.5 rounded-full bg-primary text-black font-label font-bold text-[10px] uppercase tracking-widest mb-6 border border-primary/20 anim-hero-item anim-delay-1">
        Venta, Instalación y Mantenimiento · Sabana Centro
      </span>
      
      <h1 class="text-6xl md:text-8xl font-headline font-bold tracking-tighter text-white mb-6 leading-[0.9] anim-hero-item anim-delay-2">
        Sheer<br/><span class="text-primary italic">Elegance.</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 font-body leading-relaxed max-w-2xl mb-10 anim-hero-item anim-delay-3">
        El equilibrio perfecto entre visibilidad exterior y privacidad absoluta. Somos expertos locales en Zipaquirá diseñando sistemas de bandas horizontales que redefinen el control lumínico de tu hogar.
      </p>

      <div class="flex flex-wrap gap-4 anim-hero-item anim-delay-4">
        <a href="https://wa.me/573208374532?text=Hola,%20queremos%20información%20sobre%20sus%20cortinas%20Sheer%20Elegance" target="_blank" class="group bg-gradient-to-br from-primary to-primary-container text-[#131313] font-label font-bold px-8 py-4 rounded-full flex items-center gap-3 transition-all hover:scale-105 shadow-2xl shadow-primary/20">
            Cotizar Ahora
            <span class="material-symbols-outlined -rotate-45 transition-transform duration-300 group-hover:rotate-0" data-icon="arrow_forward">arrow_forward</span>
        </a>
        
        <button onclick="openWaModal()" class="bg-[#131313]/80 backdrop-blur-md border border-white/10 text-white font-label font-bold px-8 py-4 rounded-full hover:bg-white/10 transition-all flex items-center gap-2">
            Agendar Visita
            <span class="material-symbols-outlined text-sm">calendar_month</span>
        </button>
      </div>
    </div>
  </div>
</section>