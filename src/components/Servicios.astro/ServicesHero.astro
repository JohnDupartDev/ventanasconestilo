---
/* src/components/Servicios/ServicesHero.astro */
---

<section class="relative px-6 md:px-8 pb-14 max-w-7xl mx-auto overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
    
    <div class="lg:col-span-7 reveal opacity-0 -translate-x-8 transition-all duration-1000">
      <div class="inline-flex items-center gap-3 mb-6">
        <span class="h-[1px] w-8 bg-[#dcef42]"></span>
        <span class="font-['Plus_Jakarta_Sans'] text-[#dcef42] tracking-[0.4em] uppercase text-[10px] font-black">Servicios Técnicos Especializados</span>
      </div>
      
      <h1 class="font-['Space_Grotesk'] text-5xl md:text-8xl font-black text-white leading-[0.9] tracking-tighter mb-8 uppercase">
        SOLUCIONES <br/>
        <span class="text-[#dcef42] italic">TÉCNICAS</span> PARA <br/>
        SU ESPACIO
      </h1>
      
      <p class="font-sans text-lg md:text-xl text-white/50 max-w-xl leading-relaxed italic border-l-2 border-[#dcef42]/20 pl-6">
        Más de 7 años instalando y cuidando cortinas y persianas en Zipaquirá. No improvisamos: entregamos precisión, durabilidad y un mantenimiento que realmente alarga la vida de sus sistemas.
      </p>
    </div>

    <div class="lg:col-span-5 relative reveal opacity-0 translate-y-8 transition-all duration-1000 delay-300">
      <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden shadow-2xl relative border border-white/5">
        <img 
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000 hover:scale-105" 
          alt="Instalación profesional de cortinas en Zipaquirá" 
          src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?q=80&w=600&auto=format&fit=crop"
        />
      </div>
      
      <div class="absolute -bottom-6 -left-6 p-8 bg-[#dcef42] rounded-3xl shadow-2xl shadow-[#dcef42]/20 max-w-[240px]">
        <p class="font-['Space_Grotesk'] font-black text-5xl text-[#2e3300] leading-none mb-2">7+</p>
        <p class="font-['Plus_Jakarta_Sans'] font-black text-[10px] uppercase text-[#2e3300]/80 tracking-widest">
          Años instalando en Zipaquirá y Sabana Centro.
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', '-translate-x-8', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-x-0', 'translate-y-0');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>