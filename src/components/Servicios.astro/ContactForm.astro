---
/* src/components/Servicios/ContactForm.astro */
---

<section class="px-6 md:px-8 pb-32">
  <div class="max-w-7xl mx-auto relative rounded-[3rem] overflow-hidden bg-[#131313] py-20 px-8 md:px-20 border border-white/5">
    
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <img class="w-full h-full object-cover grayscale" src="https://images.unsplash.com/photo-1505691938895-1758d7eaa511?q=80&w=1200&auto=format&fit=crop" alt="Texturas VCE" />
    </div>

    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="reveal opacity-0 -translate-x-8 transition-all duration-1000">
        <span class="text-[#dcef42] font-['Plus_Jakarta_Sans'] text-[10px] font-black tracking-[0.5em] uppercase mb-6 block italic">// Agendamiento Directo</span>
        <h2 class="font-['Space_Grotesk'] text-4xl md:text-6xl font-black text-white mb-6 uppercase tracking-tighter leading-none">
          ¿HABLAMOS DE SUS <span class="text-[#dcef42] italic">VENTANAS</span>?
        </h2>
        <p class="text-white/40 text-lg md:text-xl leading-relaxed font-sans italic">
          Déjenos sus datos y lo contactamos hoy mismo. No enviamos spam, solo soluciones técnicas y presupuestos reales para Zipaquirá y alrededores.
        </p>
      </div>

      <div class="bg-[#0e0e0e] rounded-[2.5rem] p-8 md:p-10 shadow-2xl border border-white/5 reveal opacity-0 translate-y-8 transition-all duration-1000 delay-300">
        <form id="contactForm" class="space-y-6">
          <div>
            <label class="font-['Plus_Jakarta_Sans'] text-[10px] font-black text-[#dcef42] uppercase tracking-widest mb-3 block">Nombre completo</label>
            <input 
              id="name"
              placeholder="Ej: Juan Pérez"
              class="w-full bg-[#131313] border border-white/5 rounded-2xl p-5 focus:border-[#dcef42]/50 focus:ring-0 text-white font-sans transition-all outline-none" 
              type="text"
              required
            />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="font-['Plus_Jakarta_Sans'] text-[10px] font-black text-[#dcef42] uppercase tracking-widest mb-3 block">Celular</label>
              <input 
                id="phone"
                placeholder="320..."
                class="w-full bg-[#131313] border border-white/5 rounded-2xl p-5 focus:border-[#dcef42]/50 focus:ring-0 text-white font-sans transition-all outline-none" 
                type="tel"
                required
              />
            </div>
            <div>
              <label class="font-['Plus_Jakarta_Sans'] text-[10px] font-black text-[#dcef42] uppercase tracking-widest mb-3 block">Servicio</label>
              <select id="service" class="w-full bg-[#131313] border border-white/5 rounded-2xl p-5 focus:border-[#dcef42]/50 focus:ring-0 text-white/70 font-sans transition-all outline-none appearance-none">
                <option>Venta de Cortinas</option>
                <option>Venta de Persianas</option>
                <option>Instalación Técnica</option>
                <option>Mantenimiento</option>
              </select>
            </div>
          </div>

          <button id="submitBtn" class="w-full bg-[#dcef42] text-[#2e3300] font-['Plus_Jakarta_Sans'] font-black py-6 rounded-full text-[12px] uppercase tracking-[0.3em] shadow-xl shadow-[#dcef42]/10 hover:scale-[1.02] active:scale-95 transition-all" type="submit">
            Solicitar Información
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Script de revelado
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', '-translate-x-8', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-x-0', 'translate-y-0');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Script de envío a WhatsApp con validación de tipo
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      const service = (document.getElementById('service') as HTMLSelectElement).value;
      
      const message = `Hola, mi nombre es ${name}. Estoy interesado en el servicio de: ${service}. Mi número de contacto es: ${phone}`;
      const whatsappUrl = `https://wa.me/573208374532?text=${encodeURIComponent(message)}`;
      
      window.open(whatsappUrl, '_blank');
    });
  }
</script>