          referrerpolicy="no-referrer-when-downgrade"
          class="grayscale brightness-50 opacity-60 hover:grayscale-0 hover:brightness-100 hover:opacity-100 transition-all duration-[2s] object-cover"
      ></iframe>
      <div class="absolute inset-0 flex flex-col justify-end p-10 bg-gradient-to-t from-background via-background/40 to-transparent pointer-events-none">
        <h3 class="text-3xl font-headline font-bold text-white mb-2">Presencia en Sabana Centro</h3>
        <p class="text-on-surface-variant max-w-md">Realizamos visitas técnicas y asesorías a domicilio en Zipaquirá, Cajicá, Chía y alrededores.</p>
      </div>
    </div>
    
   <div class="space-y-6">
  <div class="bg-[#dcef42]/10 rounded-[2rem] p-8 border border-[#dcef42]/20 flex flex-col justify-between h-full group hover:bg-[#dcef42]/15 transition-all cursor-pointer">
    <div>
      <div class="w-12 h-12  rounded-full flex items-center justify-center mb-6">
        <span class="material-symbols-outlined text-black" style="font-variation-settings: 'FILL' 1, 'wght' 600, 'GRAD' 0, 'opsz' 24;">
          chat
        </span>
      </div>
      
      <h3 class="text-2xl font-headline font-bold text-white mb-4">Chat Directo</h3>
      <p class="text-on-surface-variant mb-8 leading-relaxed font-body">¿Necesitas una respuesta rápida? Chatea con nuestros asesores ahora mismo.</p>
    </div>
    
    <a class="inline-flex items-center gap-3 text-primary font-label font-bold group-hover:translate-x-2 transition-transform" href="https://wa.me/573208374532">
      WhatsApp Business
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0, 'wght' 400;">
        open_in_new
      </span>
    </a>
  </div>
</div>
  </div>
</main>



<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      const msg = (document.getElementById('message') as HTMLTextAreaElement).value;
      const url = `https://wa.me/573208374532?text=${encodeURIComponent(`Hola, mi nombre es ${name}. ${msg}. Contacto: ${phone}`)}`;
      window.open(url, '_blank');
    });
  }
</script>