            <label class="font-label text-sm text-on-surface-variant ml-1">Teléfono / WhatsApp</label>
            <input id="phone" class="w-full bg-surface-container border-none rounded-xl p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all" placeholder="320 8374532" type="tel" required/>
          </div>
          <div class="space-y-1">
            <label class="font-label text-sm text-on-surface-variant ml-1">Mensaje</label>
            <textarea id="message" class="w-full bg-surface-container border-none rounded-xl p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all resize-none" placeholder="¿En qué podemos ayudarte?" rows="4" required></textarea>
          </div>
         <button class="w-full bg-primary hover:bg-lime-300 text-on-primary font-label font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 group" type="submit">
  <span class="text-on-primary">Enviar Solicitud</span>
  
  <span class="material-symbols-outlined text-on-primary transform -rotate-45 group-hover:rotate-0 transition-transform duration-500 ease-out">
