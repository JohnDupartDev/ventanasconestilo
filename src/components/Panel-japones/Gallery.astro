<script>
  function scrollGallery(direction: string) {
    const container = document.getElementById('gallery-container');
    if (!container) return;
    
    // Calculamos el ancho de una tarjeta (300px) más el gap (32px = gap-8 en Tailwind) = 332px
    const scrollAmount = 332; 
    
    if (direction === 'left') {
      container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
  }

  // Exposición global para que el onClick de Astro lo pueda llamar sin problemas de scope
  (window as any).scrollGallery = scrollGallery;
</script>
<style>
  /* Ocultar scrollbar para Chrome, Safari y Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Ocultar scrollbar para IE, Edge y Firefox */
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>