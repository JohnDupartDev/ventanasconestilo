<style>
  /* Para usar FontAwesome si no lo tienes, o puedes usar Material Icons */
  @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css');
  
  .glass {
    /* Mantenemos el efecto de brillo radial del código original pero adaptado a negro */
    background: radial-gradient(circle at top left, rgba(255, 255, 255, 0.05) 0%, rgba(0, 0, 0, 0) 70%);
  }
</style>