      <div class="flex flex-col items-center md:items-start max-w-xs text-center md:text-left">
        <a href="#" class="mb-6 flex items-center gap-3 group">
          <a href="/" class="flex items-center shrink-0 group" aria-label="Inicio - Ventanas con Estilo">
    
    <img 
      src="/logo.svg" 
      alt="Logo Ventanas con Estilo" 
      class="w-auto h-16 object-contain filter-primary group-hover:brightness-110"
      onload="this.style.opacity = 1"
      style="opacity: 0; transition: opacity 0.5s ease"
    />

</a>

          <span class="font-['Space_Grotesk'] text-2xl font-black tracking-tighter text-white uppercase italic">
