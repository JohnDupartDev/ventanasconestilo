---
/* src/components/AboutHero.astro */
---

<section class="relative bg-[#0e0e0e] pt-32 pb-20 overflow-hidden">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-[#dcef42]/[0.02] border-l border-white/5 pointer-events-none hidden lg:block"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <div class="grid grid-cols-12 gap-8 items-end">
      
      <div class="col-span-12 lg:col-span-7 reveal opacity-0 -translate-x-8 transition-all duration-1000">
        <div class="inline-flex items-center gap-3 mb-6">
            <span class="w-8 h-[1px] bg-[#dcef42]"></span>
            <span class="font-['Plus_Jakarta_Sans'] text-[#dcef42] tracking-[0.4em] uppercase text-[10px] font-black">Nuestra Trayectoria</span>
        </div>
        
        <h1 class="font-['Space_Grotesk'] text-5xl md:text-8xl font-black leading-[0.9] tracking-tighter text-white mb-10 uppercase">
          ELEVANDO EL <br/>
          <span class="text-[#dcef42] italic">ESTILO</span> EN <br/>
          ZIPAQUIRÁ.
        </h1>
        
        <p class="font-sans text-lg md:text-xl text-white/50 max-w-xl leading-relaxed italic border-l-2 border-[#dcef42]/20 pl-6">
          Desde el corazón de la Sabana Centro, transformamos espacios con la precisión de la ingeniería moderna y la calidez del diseño textil de lujo.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-5 reveal opacity-0 translate-y-8 transition-all duration-1000 delay-300">
        <div class="relative aspect-[4/5] rounded-[2.5rem] overflow-hidden shadow-2xl border border-white/5 group">
          <div class="absolute inset-0 bg-gradient-to-t from-[#0e0e0e] via-transparent to-transparent opacity-60 z-10"></div>
          
          <img 
            alt="Interior de Lujo Zipaquirá" 
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105" 
            src="/images/porque-ventanasconestilo-zipaquira.jpg"
          />

          <div class="absolute bottom-8 left-8 z-20">
            <div class="bg-[#dcef42] text-[#2e3300] px-4 py-2 rounded-full font-['Plus_Jakarta_Sans'] font-black text-[9px] tracking-widest uppercase">
                Estándar Sabana Centro
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
    // Reutilizamos el observer para las animaciones de entrada
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.remove('opacity-0', '-translate-x-8', 'translate-y-8');
                entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
    /* Efecto de ruido sutil para el fondo para dar textura de lujo */
    section::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
        opacity: 0.03;
        pointer-events: none;
    }
</style>