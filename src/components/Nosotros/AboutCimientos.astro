---
/* src/components/Nosotros/AboutCimientos.astro */
---

<section class="max-w-7xl mx-auto px-6 md:px-8 py-32 bg-[#0e0e0e]">
    <div class="reveal opacity-0 mb-16 text-center">
        <h2 class="font-['Space_Grotesk'] text-4xl md:text-5xl font-black text-white uppercase tracking-tighter">
            NUESTROS <span class="text-[#dcef42] italic">CIMIENTOS</span>
        </h2>
        <div class="w-20 h-1 bg-[#dcef42] mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="reveal opacity-0 translate-y-8 col-span-1 md:col-span-2 relative overflow-hidden group p-10 rounded-[2.5rem] border border-white/5 bg-gradient-to-br from-[#131313] to-[#0e0e0e] transition-all duration-500 hover:border-[#dcef42]/20">
            <div class="absolute top-0 right-0 p-8 text-[#dcef42]/5 transition-transform duration-700 group-hover:scale-110 group-hover:-rotate-12">
                <span class="material-icons-outlined text-[12rem]">rocket_launch</span>
            </div>
            
            <span class="text-[#dcef42] font-['Plus_Jakarta_Sans'] font-black tracking-[0.4em] text-[10px] uppercase mb-6 block italic">// Propósito</span>
            <h3 class="font-['Space_Grotesk'] text-3xl md:text-4xl font-black text-white mb-6 relative">Misión</h3>
            <p class="font-sans text-white/50 text-lg md:text-xl leading-relaxed relative max-w-xl italic">
               Brindar soluciones en cortinas y persianas que mejoren la comodidad, la luz y la privacidad de los espacios de nuestros clientes, ofreciendo venta, instalación y mantenimiento con materiales de buena calidad y precios accesibles.            </p>
        </div>

        <div class="reveal opacity-0 translate-y-8 delay-100 col-span-1 bg-[#131313] p-8 rounded-[2.5rem] border border-white/5 flex flex-col justify-between hover:bg-[#1a1a1a] transition-all group">
            <span class="material-icons-outlined text-[#dcef42] text-5xl mb-6 group-hover:scale-110 transition-transform">verified</span>
            <div>
                <h4 class="font-['Space_Grotesk'] font-black text-white text-xl mb-3 uppercase tracking-tight">Calidad Innegociable</h4>
                <p class="text-sm text-white/40 font-sans italic leading-relaxed">Materiales certificados con garantía extendida en todos nuestros mecanismos y tejidos técnicos.</p>
            </div>
        </div>

        <div class="reveal opacity-0 translate-y-8 delay-200 col-span-1 bg-[#131313] p-8 rounded-[2.5rem] border border-white/5 flex flex-col justify-between hover:bg-[#1a1a1a] transition-all group">
            <span class="material-icons-outlined text-[#dcef42] text-5xl mb-6 group-hover:scale-110 transition-transform">schedule</span>
            <div>
                <h4 class="font-['Space_Grotesk'] font-black text-white text-xl mb-3 uppercase tracking-tight">Puntualidad</h4>
                <p class="text-sm text-white/40 font-sans italic leading-relaxed">Respetamos su tiempo. Entregas e instalaciones coordinadas con precisión milimétrica en la Sabana.</p>
            </div>
        </div>

        <div class="reveal opacity-0 translate-y-8 delay-300 col-span-1 md:col-span-1 bg-[#dcef42] p-10 rounded-[2.5rem] group overflow-hidden relative">
            <div class="relative z-10">
                <h3 class="font-['Space_Grotesk'] text-3xl font-black text-[#2e3300] mb-6 uppercase tracking-tighter italic">Visión 2030</h3>
                <p class="font-sans text-[#2e3300]/80 font-bold leading-relaxed">
                    Ser reconocidos como el estudio de diseño de ventanas más influyente de Cundinamarca, liderando la transición hacia hogares inteligentes y sostenibles.
                </p>
            </div>
            <span class="absolute -bottom-10 -right-10 material-icons-outlined text-[10rem] text-[#2e3300]/5 group-hover:rotate-12 transition-transform duration-700">visibility</span>
        </div>

        <div class="reveal opacity-0 translate-y-8 delay-400 col-span-1 bg-[#131313] p-8 rounded-[2.5rem] border border-white/5 flex flex-col justify-between hover:bg-[#1a1a1a] transition-all group">
            <span class="material-icons-outlined text-[#dcef42] text-5xl mb-6 group-hover:scale-110 transition-transform">handshake</span>
            <div>
                <h4 class="font-['Space_Grotesk'] font-black text-white text-xl mb-3 uppercase tracking-tight">Confianza</h4>
                <p class="text-sm text-white/40 font-sans italic leading-relaxed">Asesoría honesta. No vendemos solo cortinas, creamos relaciones a largo plazo basadas en la transparencia.</p>
            </div>
        </div>

    </div>
</section>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                entry.target.classList.add('opacity-100', 'translate-y-0');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>