---
/* src/components/Nosotros/AboutCTA.astro */
---

<section class="py-24 bg-[#0e0e0e] px-6 md:px-8 relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#dcef42]/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="bg-[#131313] border border-white/5 rounded-[3rem] md:rounded-[4rem] p-10 md:p-10 text-center shadow-2xl relative overflow-hidden group">
      
      <div class="absolute top-0 left-0 w-20 h-20 border-t-2 border-l-2 border-[#dcef42]/20 rounded-tl-[3rem] md:rounded-tl-[4rem]"></div>
      <div class="absolute bottom-0 right-0 w-20 h-20 border-b-2 border-r-2 border-[#dcef42]/20 rounded-br-[3rem] md:rounded-br-[4rem]"></div>

      <div class="reveal opacity-0 translate-y-8 transition-all duration-1000">
        <span class="text-[#dcef42] font-['Plus_Jakarta_Sans'] font-black tracking-[0.5em] text-[10px] md:text-[12px] uppercase mb-6 block italic">
          // ¿Hablamos de su proyecto?
        </span>
        
        <h2 class="font-['Space_Grotesk'] text-4xl md:text-6xl font-black text-white mb-8 uppercase tracking-tighter leading-[0.9]">
          LLEVEMOS EL <span class="text-[#dcef42] italic">DISEÑO</span> <br class="hidden md:block"/> 
          A SUS VENTANAS
        </h2>
        
        <p class="text-white/40 text-base md:text-xl mb-12 max-w-2xl mx-auto font-sans italic leading-relaxed">
          Únase a los más de 900 hogares en la Sabana Centro que ya disfrutan de la perfecta combinación entre tecnología y elegancia.
        </p>

        <div class="flex flex-col md:flex-row items-center justify-center gap-6">
          <a 
            href="https://wa.me/573208374532?text=Hola,%20vengo%20de%20la%20web%20y%20quiero%20asesoría%20personalizada"
            target="_blank"
            class="w-full md:w-auto bg-[#dcef42] text-[#2e3300] px-10 py-5 rounded-full font-['Plus_Jakarta_Sans'] font-black text-xs md:text-sm uppercase tracking-[0.2em] hover:scale-105 active:scale-95 transition-all duration-500 shadow-xl shadow-[#dcef42]/10"
          >
            Agendar Visita Técnica
          </a>
          
          <a 
            href="tel:+573208374532"
            class="w-full md:w-auto border border-white/10 text-white px-10 py-5 rounded-full font-['Plus_Jakarta_Sans'] font-black text-xs md:text-sm uppercase tracking-[0.2em] hover:bg-white/5 transition-all duration-500"
          >
            Llamar Directo
          </a>
        </div>

     <div class="mt-8 pt-8 border-t border-white/5 flex flex-wrap items-center justify-center gap-x-6 gap-y-4 md:gap-8 opacity-30">
    <span class="text-[9px] font-black text-white uppercase tracking-[0.3em]">Zipaquirá</span>
    
    <span class="hidden md:block w-1 h-1 bg-white rounded-full"></span>
    
    <span class="text-[9px] font-black text-white uppercase tracking-[0.3em]">Chía</span>
    
    <span class="hidden md:block w-1 h-1 bg-white rounded-full"></span>
    
    <span class="text-[9px] font-black text-white uppercase tracking-[0.3em]">Cajicá</span>
    
    <span class="hidden md:block w-1 h-1 bg-white rounded-full"></span>
    
    <span class="text-[9px] font-black text-white uppercase tracking-[0.3em]">Sabana Centro</span>
</div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>