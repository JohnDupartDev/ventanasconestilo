---
import AboutCTA from '../components/Nosotros/AboutCTA.astro';
import FAQ from '../components/Productos/FAQ.astro';
import HeroProducts from '../components/Productos/HeroProducts.astro';
import ProductsGrid from '../components/Productos/ProductsGrid.astro';
import Layout from '../layouts/Layout.astro';


/** * SEO & GEO Optimization - Productos */
const title = "Cortinas y Persianas en Zipaquirá | Catálogo Premium";
const description = "Explora nuestro catálogo exclusivo de cortinas y persianas en Zipaquirá. Calidad, diseño y control solar profesional para hogares y oficinas en la Sabana Centro.";

const canonicalURL = Astro.site 
  ? new URL(Astro.url.pathname, Astro.site) 
  : Astro.url.pathname;
---

<Layout title={title} description={description}>
  {Astro.site && <link rel="canonical" href={canonicalURL} slot="head" />}
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

 <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Catálogo de Cortinas y Persianas - Ventanas con Estilo",
      "description": "Explora nuestra selección premium de soluciones para ventanas en Zipaquirá y la Sabana Centro.",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Cortinas Sheer Elegance",
          "url": "https://ventanasconestilo.com/productos/sheer-elegance"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Cortinas Romanas",
          "url": "https://ventanasconestilo.com/productos/romanas"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Panel Japonés",
          "url": "https://ventanasconestilo.com/productos/panel-japones"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Cortinas Enrollables (Roller)",
          "url": "https://ventanasconestilo.com/productos/enrollables"
        },
        {
          "@type": "ListItem",
          "position": 5,
          "name": "Cortinas Blackout",
          "url": "https://ventanasconestilo.com/productos/blackout"
        },
        {
          "@type": "ListItem",
          "position": 6,
          "name": "Películas de Protección Solar",
          "url": "https://ventanasconestilo.com/productos/peliculaa-solares"
        }
      ],
      "provider": {
        "@type": "LocalBusiness",
        "name": "Ventanas con Estilo",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Zipaquirá",
          "addressRegion": "Cundinamarca",
          "addressCountry": "CO"
        },
        "priceRange": "$$$"
      }
    }
  </script>

  <section class="bg-[#0e0e0e] pt-32">
   <HeroProducts />
   <ProductsGrid />
   <FAQ />
    <AboutCTA />

  </section>
</Layout>

<script>
  // Script de revelado optimizado para productos
  const observerOptions = {
    threshold: 0.1,
    rootMargin: "0px 0px -50px 0px"
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  /* Estilo base para elementos que deben aparecer con scroll */
  .reveal {
    transition: opacity 1s ease-out, transform 1s ease-out;
  }
</style>