---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Home/Hero.astro';
import ProblemSolutions from '../components/Home/ProblemSolution.astro';
import Brands from '../components/Home/Brands.astro';
import Products from '../components/Home/Products.astro';
import WhyChooseUs from '../components/Home/WhyChooseUs.astro';
import Testimonials from '../components/Home/Testimonials.astro';
import FAQ from '../components/Home/FAQ.astro';
import Contact from '../components/Home/Contact.astro';
import FinalCTA from '../components/Home/FinalCTA.astro';

/** * SEO Optimization - Index Principal
 * Estrategia: Posicionamiento local en Sabana Centro y autoridad en Motorización.
 */
const title = "Ventanas con Estilo | Cortinas y Persianas en Zipaquirá";
const description = "Especialistas en cortinas y persianas en Zipaquirá. Ofrecemos venta, instalación y mantenimiento con soluciones prácticas para mejorar la luz, la privacidad y el ambiente de sus espacios.";

// Validación de seguridad para la URL
const canonicalURL = Astro.site 
  ? new URL(Astro.url.pathname, Astro.site) 
  : Astro.url.pathname;
---

<Layout title={title} description={description}>
  {Astro.site && <link rel="canonical" href={canonicalURL} slot="head" />}

  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": "Ventanas con Estilo",
      "image": "https://ventanasconestilo.com/og-image.jpg", 
      "@id": "https://ventanasconestilo.com",
      "url": "https://ventanasconestilo.com",
      "telephone": "+573208374532",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Zona Sabana Centro",
        "addressLocality": "Zipaquirá",
        "addressRegion": "Cundinamarca",
        "postalCode": "250252",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 5.0233,
        "longitude": -73.9931
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        "https://www.instagram.com/ventanasconestilo",
        "https://wa.me/573208374532"
      ],
      "areaServed": [
        { "@type": "City", "name": "Zipaquirá" },
        { "@type": "City", "name": "Chía" },
        { "@type": "City", "name": "Cajicá" },
        { "@type": "City", "name": "Briceño" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Ventanería Técnica",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Motorización de Persianas"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Instalación de Cortinas Enrollables"
            }
          }
        ]
      }
    }
  </script>

  <main>
    <Hero />
    <ProblemSolutions />
    <Brands />
    <Products />
    <WhyChooseUs />
    <Testimonials />
    <FAQ />
    <Contact />
    <FinalCTA />
  </main>
</Layout>

<style is:global>
  /* Suavizado de scroll para toda la Home */
  html {
    scroll-behavior: smooth;
  }
</style>