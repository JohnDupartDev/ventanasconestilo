---
import CTA from '../../components/Panel-japones/CTA.astro';
import Features from '../../components/Panel-japones/Features.astro';
import Gallery from '../../components/Panel-japones/Gallery.astro';
import Hero from '../../components/Panel-japones/Hero.astro';
import Technical from '../../components/Panel-japones/Technical.astro';
import Layout from '../../layouts/Layout.astro';

/** * ==========================================
 * SEO & GEO Optimization - Panel Japonés
 * ==========================================
 */
const title = "Cortinas Panel Japonés en Zipaquirá y Sabana Centro | Ventanas con Estilo";
const description = "Diseño minimalista oriental con nuestras Cortinas Panel Japonés. Fabricación a medida e instalación en Zipaquirá, Chía, Cajicá, Sopó y Tocancipá. Visita técnica gratis.";
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : "https://ventanasconestilo.com/productos/cortinas-panel-japones";

const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "Cortinas Panel Japonés",
  "image": "https://ventanasconestilo.com/wp-content/uploads/2023/10/panel-japones-sakura.jpg",
  "description": "Cortinas de estilo minimalista oriental compuestas por lienzos de tela independientes que se deslizan sobre un riel. Ideales para ventanales de piso a techo y división de espacios.",
  "brand": {
    "@type": "Brand",
    "name": "Ventanas con Estilo"
  },
  "offers": {
    "@type": "AggregateOffer",
    "url": canonicalURL,
    "priceCurrency": "COP",
    "availability": "https://schema.org/InStock",
    "priceValidUntil": "2026-12-31",
    "areaServed": ["Zipaquirá", "Chía", "Cajicá", "Sopó", "Tocancipá"]
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Ventanas con Estilo",
  "image": "https://ventanasconestilo.com/logo.png",
  "description": "Expertos en cortinas, persianas y control solar en Sabana Centro.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Carrera 19 # 17 - 22",
    "addressLocality": "Zipaquirá",
    "addressRegion": "Cundinamarca",
    "addressCountry": "CO"
  },
  "areaServed": [
    { "@type": "City", "name": "Zipaquirá" },
    { "@type": "City", "name": "Chía" },
    { "@type": "City", "name": "Cajicá" },
    { "@type": "City", "name": "Sopó" },
    { "@type": "City", "name": "Tocancipá" }
  ],
  "telephone": "+573208374532",
  "priceRange": "$$"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Para qué tipo de ventanas sirve el Panel Japonés?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Es ideal para ventanas de gran tamaño, puertas corredizas, ventanales de piso a techo y también funciona perfectamente como un divisor de espacios elegante dentro del hogar u oficina."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen instalación de Panel Japonés en Chía o Cajicá?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, realizamos visitas técnicas gratuitas para toma de medidas e instalación certificada en Chía, Cajicá, Zipaquirá, Sopó, Tocancipá y toda la Sabana Centro."
      }
    }
  ]
};
---

<Layout title={title} description={description}>
      <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head"></script>

  <main class="w-full">
    <div class="reveal opacity-0 translate-y-8 transition-all duration-[1000ms] ease-out">
      <Hero />
    </div>
    
    <div class="reveal opacity-0 translate-y-8 transition-all duration-[1000ms] ease-out">
      <Features />
    </div>
    
    <div class="reveal opacity-0 translate-y-8 transition-all duration-[1000ms] ease-out">
      <Technical />
    </div>
    
    <div class="reveal opacity-0 translate-y-8 transition-all duration-[1000ms] ease-out">
      <Gallery />
    </div>
    
    <CTA />
  </main>
 
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>