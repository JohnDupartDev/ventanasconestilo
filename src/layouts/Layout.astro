---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ScrollCTA from "../components/ScrollCTA.astro";
import '../styles/global.css'; 

/**
 * PROPS DEL LAYOUT
 * Se incluyen valores por defecto optimizados para SEO local.
 */
const { 
  title = "Ventanas con Estilo | Cortinas & Persianas en Zipaquirá y Sabana Centro", 
  description = "Especialistas en venta, instalación y mantenimiento de cortinas Sheer Elegance, Panel Japonés y persianas. + 6 años de garantía y visita técnica gratuita en Zipaquirá, Chía y Cajicá.",
  url = "https://ventanasconestilo.com", 
  image = "/images/og-ventanas-con-estilo.jpg", // Ruta recomendada para la imagen OG
  canonical = Astro.url.href
} = Astro.props;

/**
 * SCHEMA.ORG - JSON-LD ROBUSTO (SEO & AEO)
 * Combinación de LocalBusiness y Service para máxima visibilidad en búsquedas y asistentes de IA.
 */
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "@id": "https://ventanasconestilo.com/#organization",
      "name": "Ventanas con Estilo",
      "url": "https://ventanasconestilo.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://ventanasconestilo.com/logo.png",
        "width": "512",
        "height": "512"
      },
      "image": "https://ventanasconestilo.com/images/hero-home.jpg",
      "description": "Expertos en diseño, instalación y mantenimiento de cortinas y persianas premium en la Sabana de Bogotá.",
      "telephone": "+573208374532",
      "email": "contacto@ventanasconestilo.com",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Carrera 19 # 17 - 22", // Dirección consolidada
        "addressLocality": "Zipaquirá",
        "addressRegion": "Cundinamarca",
        "postalCode": "250251",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 5.019, 
        "longitude": -73.997
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=100091404444825",
        "https://www.instagram.com/ventanasconestilo/",
        "https://www.tiktok.com/@ventanas_con_estilo"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+573208374532",
        "contactType": "sales",
        "areaServed": ["Zipaquirá", "Chía", "Cajicá", "Sopó", "Tocancipá"],
        "availableLanguage": "Spanish"
      }
    },
    {
      "@type": "Service",
      "serviceType": "Instalación de Cortinas y Persianas",
      "provider": { "@id": "https://ventanasconestilo.com/#organization" },
      "areaServed": {
        "@type": "State",
        "name": "Cundinamarca"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Catálogo de Cortinas",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cortinas Sheer Elegance" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Panel Japonés" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Persianas Enrollables" } }
        ]
      }
    }
  ]
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#131313" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow" />
        
        <meta property="og:type" content="website" />
        <meta property="og:url" content={url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="es_CO" />
        <meta property="og:site_name" content="Ventanas con Estilo" />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, Astro.url)} />

        <meta name="geo.region" content="CO-CUN" />
        <meta name="geo.placename" content="Zipaquirá" />
        <meta name="geo.position" content="5.019;-73.997" />
        <meta name="ICBM" content="5.019, -73.997" />

        <meta name="keywords" content="cortinas sheer elegance zipaquira, persianas panel japones chia, instalacion de cortinas cajica, mantenimiento de persianas sopo, persianas modernas sabana centro, ventanas con estilo, cortinas a medida cundinamarca" />
        <meta name="author" content="Ventanas con Estilo" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Plus+Jakarta+Sans:wght@700;800&family=Space+Grotesk:wght@700;900&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

        <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

        <script is:inline>
            const getTheme = () => {
              if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                return localStorage.getItem('theme');
              }
              return 'dark';
            };

            const setTheme = (theme) => {
              if (theme === 'light') {
                document.documentElement.classList.add('light');
              } else {
                document.documentElement.classList.remove('light');
              }
              localStorage.setItem('theme', theme);
            };

            setTheme(getTheme());
            document.addEventListener('astro:after-swap', () => setTheme(getTheme()));
        </script>

        <slot name="head" />
    </head>
    <body class="bg-surface text-on-surface antialiased selection:bg-primary selection:text-on-primary">
        <Header />
        
        <main id="main-content">
            <slot />
        </main>

        <Footer />
        <ScrollCTA />
    </body>
</html>

<style is:global>
  /* 1. Definición de variables puras */
  :root {
    --bg-page: #131313;
    --text-page: #e2e2e2;
    --bg-card: #1f1f1f;
    --border-color: rgba(70, 72, 52, 0.15);
    --primary: #dcef42; /* Color Lima Marca */
  }

  /* 2. Inversión total en modo claro */
  :root.light {
    --bg-page: #f9f9f9;
    --text-page: #131313;
    --bg-card: #ffffff;
    --border-color: rgba(0, 0, 0, 0.08);
  }

  /* 3. Estilos Base */
  html, body {
    background-color: var(--bg-page) !important;
    color: var(--text-page) !important;
    transition: background-color 0.3s ease, color 0.3s ease;
    font-family: 'Inter', sans-serif;
  }

  h1, h2, h3, h4 {
    font-family: 'Space Grotesk', sans-serif;
  }

  /* Clases de utilidad manuales */
  .bg-surface { background-color: var(--bg-page) !important; }
  .bg-surface-container { background-color: var(--bg-card) !important; }
  .text-on-surface { color: var(--text-page) !important; }
  .border-outline-variant { border-color: var(--border-color) !important; }

  /* Personalización de Scrollbar */
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg-page);
  }
  ::-webkit-scrollbar-thumb {
    background: #333;
    border-radius: 5px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
  }

  /* Soporte para no-scrollbar */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>